# ============================================================
# DataPulse — Environment Configuration
# ============================================================
# Copy to .env and replace all <GENERATE> placeholders with
# real values:
#   cp .env.example .env
#
# Spring Boot also reads this file via spring.config.import
# (no separate secrets file needed).
#
# .env is gitignored — secrets stay local.
#
# To generate a random password (PowerShell):
#   -join ((1..16) | % { 'abcdefghijkmnpqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ23456789'[(Get-Random -Max 58)] })
#
# To generate COOKIE_SECRET (32-byte base64, PowerShell):
#   $b = New-Object byte[] 32; (New-Object Security.Cryptography.RNGCryptoServiceProvider).GetBytes($b); [Convert]::ToBase64String($b)
# ============================================================

# === Active environment ===
# Determines which docker-compose override and nginx config to use.
#
# local  — backend + frontend run natively; infra in Docker
# docker — everything in Docker
#
# On Windows the separator is ";" — on Mac/Linux use ":"
COMPOSE_FILE=docker-compose.yml;docker-compose.local.yml
# COMPOSE_FILE=docker-compose.yml;docker-compose.docker.yml

# === Server ===
SERVER_PORT=8081
# JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC

# === PostgreSQL ===
POSTGRES_USER=datapulse
POSTGRES_PASSWORD=<GENERATE>
POSTGRES_DB=datapulse
DB_SCHEMA=datapulse
# Optional: full JDBC-style URL for Cursor MCP (scripts/mcp-postgres-launcher.mjs).
# If unset, the launcher builds postgresql:// from POSTGRES_* / DB_HOST / DB_PORT / DB_SCHEMA.
# POSTGRES_MCP_URL=postgresql://datapulse:secret@localhost:5432/datapulse?options=-csearch_path%3Ddatapulse

# === ClickHouse ===
CH_USERNAME=default
CH_PASSWORD=<GENERATE>
CH_DATABASE=datapulse
CH_MIGRATION_ENABLED=true

# === Keycloak ===
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<GENERATE>
KEYCLOAK_REALM=datapulse
# Public Keycloak hostname exposed by container metadata.
# local native: localhost / 8180
# docker/prod: set to your public hostname (+443 or custom HTTPS port)
KEYCLOAK_PUBLIC_HOSTNAME=localhost
KEYCLOAK_PUBLIC_PORT=8180

# === Public URLs (single source of truth for callbacks/issuer/invitations) ===
# local native mode:
#   PUBLIC_APP_URL=http://localhost:4200
#   PUBLIC_EDGE_URL=http://localhost:8880
#   PUBLIC_KEYCLOAK_URL=http://localhost:8180
#   KEYCLOAK_INTERNAL_URL=http://localhost:8180
#
# docker mode (all services in Docker via nginx):
#   PUBLIC_APP_URL=http://localhost:8880
#   PUBLIC_EDGE_URL=http://localhost:8880
#   PUBLIC_KEYCLOAK_URL=http://localhost:8880
#   KEYCLOAK_INTERNAL_URL=http://keycloak:8080/auth
PUBLIC_APP_URL=http://localhost:4200
PUBLIC_EDGE_URL=http://localhost:8880
PUBLIC_KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_INTERNAL_URL=http://localhost:8180

# === RabbitMQ ===
RABBITMQ_USER=datapulse
RABBITMQ_PASSWORD=<GENERATE>

# === MinIO / S3 ===
MINIO_ROOT_USER=datapulse
MINIO_ROOT_PASSWORD=<GENERATE>
S3_ACCESS_KEY=datapulse
S3_SECRET_KEY=<GENERATE>
S3_RAW_BUCKET=datapulse-raw

# === Vault ===
VAULT_TOKEN=<GENERATE>
VAULT_BASE_PATH=secret/data/datapulse
VAULT_CREDENTIAL_CACHE_TTL=1h

# === OAuth2 Proxy ===
OAUTH2_PROXY_CLIENT_ID=datapulse-proxy
OAUTH2_PROXY_CLIENT_SECRET=<GENERATE>
COOKIE_SECRET=<GENERATE-32-CHARS>
# Optional: oauth2-proxy encrypted session cookie (default 168h / 30m refresh — see docker-compose.yml)
# OAUTH2_PROXY_COOKIE_EXPIRE=168h
# OAUTH2_PROXY_COOKIE_REFRESH=30m

# === Keycloak realm timings (infra/init/keycloak/realm-export.json) ===
# Re-import realm or mirror in Admin UI: Tokens / Sessions.
# Current export targets BFF (oauth2-proxy): access token 10m, SSO idle 1h, SSO max 12h.

# === Mail ===
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@datapulse.io

# === Hosts ===
# local  → localhost (backend reaches infra via mapped ports)
# docker → Docker service names (backend is inside the network)
DB_HOST=localhost
CH_HOST=localhost
RABBITMQ_HOST=localhost
REDIS_HOST=localhost
KEYCLOAK_HOST=localhost
VAULT_HOST=localhost
S3_HOST=localhost
WIREMOCK_HOST=localhost

# Uncomment for docker environment:
# DB_HOST=postgres
# CH_HOST=clickhouse
# RABBITMQ_HOST=rabbitmq
# REDIS_HOST=redis
# KEYCLOAK_HOST=keycloak
# VAULT_HOST=vault
# S3_HOST=minio
# WIREMOCK_HOST=wiremock

# === Ports ===
DB_PORT=5432
CH_PORT=8123
RABBITMQ_PORT=5672
REDIS_PORT=6379
KEYCLOAK_PORT=8180
VAULT_PORT=8200
S3_PORT=9010
WIREMOCK_PORT=9091
NGINX_PORT=8880

# === Outbox ===
OUTBOX_ENABLED=true
OUTBOX_RUNTIME=ALL

# === Management / Actuator ===
MANAGEMENT_ENDPOINTS_INCLUDE=health,info,prometheus,metrics
MANAGEMENT_HEALTH_SHOW_DETAILS=when-authorized

# === LLM (AI features) ===
# URL of the vLLM server (OpenAI-compatible API).
# Empty = AI features disabled (graceful degradation, core functionality unaffected).
# If LLM runs on the same machine: http://localhost:8100/v1
# If LLM runs on a separate server: http://<llm-server-ip>:8100/v1
LLM_BASE_URL=
LLM_MODEL_NAME=datapulse
LLM_TIMEOUT_FAST=2000
LLM_TIMEOUT_SLOW=15000

# === Production (only for docker-compose.prod.yml) ===
# PUBLIC_APP_URL=https://your-domain.example
# PUBLIC_EDGE_URL=https://your-domain.example
# PUBLIC_KEYCLOAK_URL=https://your-domain.example
# KEYCLOAK_PUBLIC_HOSTNAME=your-domain.example
# KEYCLOAK_PUBLIC_PORT=443
# KEYCLOAK_INTERNAL_URL=http://keycloak:8080/auth
# PROD_NGINX_PORT=8880

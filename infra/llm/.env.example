# ============================================================
# DataPulse LLM Server — Environment Configuration
# ============================================================
# Copy to .env and adjust if needed:
#   cp .env.example .env
#
# .env is gitignored — secrets stay local.
# ============================================================

# === Model ===
# Swap model without any code changes — just edit and restart.
# Growth path: Qwen3-8B (12GB) → Qwen3-14B (16GB) → Qwen3-30B-A3B MoE (24GB)
LLM_MODEL=Qwen/Qwen3-8B
LLM_QUANTIZATION=gptq

# === Inference ===
# max-model-len: token limit per request (prompt + response).
#   4096 is sufficient for all Tier 1 features (F1, F8, F10).
# gpu-memory-utilization: fraction of VRAM for model + KV-cache.
#   0.90 is safe for 12GB cards (3060/3080 Ti). Lower if OOM.
# max-num-seqs: max concurrent requests in a batch.
#   8 handles 10-20 active users comfortably on 12GB VRAM.
LLM_MAX_CONTEXT=4096
LLM_GPU_MEM_UTIL=0.90
LLM_MAX_CONCURRENT=8

# === Network ===
# Port exposed on host. Backend connects to http://<llm-host>:<port>/v1
LLM_PORT=8100

# === HuggingFace (optional) ===
# Required only for gated models. Qwen3-8B is open — leave empty.
HF_TOKEN=
